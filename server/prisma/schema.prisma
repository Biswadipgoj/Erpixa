generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Lead {
  id          String   @id @default(uuid())
  name        String
  partner     String
  stage       String
  probability Int
  revenue     Float
  user        String
  priority    Int
  tag         String
  created     String
}

model SalesOrder {
  id          String   @id @default(uuid())
  customer    String
  date        String
  total       Float
  status      String
  salesperson String
}

model Product {
  id       String   @id @default(uuid())
  name     String
  category String
  qty      Int
  price    Float
  status   String
}

model Invoice {
  id       String   @id @default(uuid())
  customer String
  date     String
  due      String
  amount   Float
  status   String
  payment  String
}

model Employee {
  id       String   @id @default(uuid())
  name     String
  role     String
  dept     String
  email    String
  phone    String
  status   String
  joinDate String
  initials String
  color    String
}

model Project {
  id       String   @id @default(uuid())
  name     String
  client   String
  status   String
  progress Int
  dueDate  String
  team     String   // comma-separated
  tasks    Int
  done     Int
}

model ProjectTask {
  id       String   @id @default(uuid())
  title    String
  project  String
  stage    String
  assignee String
  priority String
  due      String
}

model ManufacturingOrder {
  id         String   @id @default(uuid())
  product    String
  qty        Int
  bom        String
  status     String
  scheduled  String
  workcenter String
}

model Ticket {
  id       String   @id @default(uuid())
  title    String
  customer String
  priority String
  status   String
  assignee String
  created  String
}
